@page "/member-dashboard"
@namespace MicroGym.Client.Pages
@using BaseApplicationMethods
@attribute [Authorize]
@layout MainLayout
@inherits BaseApplication

<PageTitle>Members - MicroGym</PageTitle>

<div class="dashboard">

    <!-- ═══ Header ═══ -->
    <div class="dash-header">
        <div>
            <h1 class="dash-title">Member Dashboard</h1>
            <p class="dash-sub">Manage and monitor all gym members</p>
        </div>
        <button class="ant-btn ant-btn-primary gym-btn-primary" @onclick="OpenModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            Add New Member
        </button>
    </div>

    <!-- ═══ Stats Cards ═══ -->
    <div class="stats-row">

        <div class="ant-card gym-stat-card gym-stat-card--total @(statusFilter == "" ? "gym-stat-card--selected" : "")"
             @onclick='() => OnCardFilter("")'>
            <div class="ant-card-body">
                <div class="ant-statistic">
                    <div class="ant-statistic-title">Total Members</div>
                    <div class="ant-statistic-content">
                        <span class="ant-statistic-content-value">@totalMembers</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="ant-card gym-stat-card gym-stat-card--active @(statusFilter == "Active" ? "gym-stat-card--selected" : "")"
             @onclick='() => OnCardFilter("Active")'>
            <div class="ant-card-body">
                <div class="ant-statistic">
                    <div class="ant-statistic-title">Active</div>
                    <div class="ant-statistic-content">
                        <span class="ant-statistic-content-value stat-green">@activeMembers</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="ant-card gym-stat-card gym-stat-card--inactive @(statusFilter == "Inactive" ? "gym-stat-card--selected" : "")"
             @onclick='() => OnCardFilter("Inactive")'>
            <div class="ant-card-body">
                <div class="ant-statistic">
                    <div class="ant-statistic-title">Inactive</div>
                    <div class="ant-statistic-content">
                        <span class="ant-statistic-content-value stat-red">@inactiveMembers</span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ═══ Toolbar: Search ═══ -->
    <div class="toolbar">
        <span class="ant-input-affix-wrapper ant-input-affix-wrapper-lg gym-input search-input">
            <span class="ant-input-prefix">🔍</span>
            <input class="ant-input"
                   type="text"
                   placeholder="Search by name or email..."
                   value="@searchText"
                   @oninput="OnSearchInput" />
        </span>
    </div>

    <!-- ═══ Table ═══ -->
    <div class="ant-card gym-table-card">
        <div class="ant-card-body" style="padding: 0;">

            @if (isLoading)
            {
                <div class="table-state">
                    <div class="loader"></div>
                    <span>Loading members...</span>
                </div>
            }
            else if (!filteredMembers.Any())
            {
                <div class="table-state">
                    <span style="font-size: 2rem; opacity: 0.3;">📋</span>
                    <span>No members found.</span>
                </div>
            }
            else
            {
                <div class="ant-table-wrapper">
                    <table class="ant-table gym-table">
                        <thead class="ant-table-thead">
                            <tr>
                                <th class="ant-table-cell">Member</th>
                                <th class="ant-table-cell">Phone</th>
                                <th class="ant-table-cell">Date Joined</th>
                                <th class="ant-table-cell">Membership Status</th>
                                <th class="ant-table-cell">Expiry</th>
                                <th class="ant-table-cell">Last Visit</th>
                                <th class="ant-table-cell">Action</th>
                            </tr>
                        </thead>
                        <tbody class="ant-table-tbody">
                            @foreach (var member in pagedMembers)
                            {
                                <tr class="ant-table-row ant-table-row-level-0">
                                    <td class="ant-table-cell">
                                        <div style="display:flex;align-items:center;gap:0.65rem;">
                                            <div class="member-avatar-sm">@member.FirstName[0]@member.LastName[0]</div>
                                            <div>
                                                <div class="cell-name">@member.FirstName @member.LastName</div>
                                                <div class="cell-muted" style="font-size:0.75rem;">@member.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="ant-table-cell cell-muted">@(member.Phone ?? "—")</td>
                                    <td class="ant-table-cell cell-muted">@member.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="ant-table-cell">
                                        @if (member.IsActive)
                                        {
                                            <span class="ant-tag ant-tag-green">Active</span>
                                        }
                                        else
                                        {
                                            <span class="ant-tag ant-tag-red">Inactive</span>
                                        }
                                    </td>
                                    <td class="ant-table-cell cell-muted">@FormatExpiryDate(member.ExpiryDate)</td>
                                    <td class="ant-table-cell cell-muted">@FormatLastVisit(member.LastVisit)</td>
                                    <td class="ant-table-cell">
                                        <div style="display:flex;gap:8px;">
                                            <button class="ant-btn gym-icon-btn gym-icon-btn--edit"
                                                    title="Edit"
                                                    @onclick="() => OnEdit(member)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                            </button>
                                            <button class="ant-btn gym-icon-btn gym-icon-btn--delete"
                                                    title="Delete"
                                                    @onclick="@(() => OnDelete(member))">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="3 6 5 6 21 6" />
                                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                                    <path d="M10 11v6M14 11v6" />
                                                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (totalPages > 1)
                    {
                        <div class="gym-pagination">
                            <span class="gym-pagination-info">
                                Showing @((currentPage - 1) * PageSize + 1)–@(Math.Min(currentPage * PageSize, filteredMembers.Count)) of @filteredMembers.Count members
                            </span>
                            <div class="gym-pagination-controls">
                                <button class="gym-page-btn" disabled="@(currentPage == 1)"
                                        @onclick="() => currentPage = 1">«</button>
                                <button class="gym-page-btn" disabled="@(currentPage == 1)"
                                        @onclick="() => currentPage--">‹</button>

                                @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                                {
                                    var pageNum = p;
                                    <button class="gym-page-btn @(pageNum == currentPage ? "gym-page-btn--active" : "")"
                                            @onclick="() => currentPage = pageNum">@pageNum</button>
                                }

                                <button class="gym-page-btn" disabled="@(currentPage == totalPages)"
                                        @onclick="() => currentPage++">›</button>
                                <button class="gym-page-btn" disabled="@(currentPage == totalPages)"
                                        @onclick="() => currentPage = totalPages">»</button>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

</div>

<!-- ═══ Edit Member Modal ═══ -->
<EditMemberModal UserId="editUserId"
                 IsOpen="showEditModal"
                 OnClose="EventCallback.Factory.Create(this, CloseEditModal)"
                 OnMemberUpdated="EventCallback.Factory.Create(this, async () => { allMembers = await GetMembers(); HandleSearch(); })" />

<!-- ═══ Delete Confirm Modal ═══ -->
<GymModal IsOpen="showDeleteModal && memberToDelete is not null"
          Title="Delete Member"
          MaxWidth="420px"
          OnClose="CloseDeleteModal">

    <p style="margin:0 0 1.25rem;color:#9CA3AF;">
        Are you sure you want to delete
        <strong style="color:#F9FAFB;">@memberToDelete?.FirstName @memberToDelete?.LastName</strong>?
        This will also remove all their payment records and cannot be undone.
    </p>
    <div class="gym-modal-footer">
        <button class="ant-btn" @onclick="CloseDeleteModal">Cancel</button>
        <button class="ant-btn gym-btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
            @if (isDeleting)
            {
                <span class="btn-spinner"></span>
                <span>Deleting...</span>
            }
            else
            {
                <span>🗑 Delete</span>
            }
        </button>
    </div>

</GymModal>

<!-- ═══ Add New Member Modal ═══ -->
<AddMemberModal IsOpen="showAddModal"
                OnClose="EventCallback.Factory.Create(this, CloseAddModal)"
                OnMemberAdded="EventCallback.Factory.Create(this, async () => { allMembers = await GetMembers(); HandleSearch(); })" />
