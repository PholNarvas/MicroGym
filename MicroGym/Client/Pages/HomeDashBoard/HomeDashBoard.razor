@page "/"
@using BaseApplicationMethods
@using MicroGym.Shared.Model
@attribute [Authorize]
@layout MainLayout
@inherits BaseApplication

<PageTitle>Home - MicroGym</PageTitle>

<div class="dashboard">

    <!-- ═══ Header ═══ -->
    <div class="dash-header">
        <div>
            <h1 class="dash-title">@GetGreeting()@(currentUserName.Length > 0 ? $", {currentUserName}" : "")!</h1>
            <p class="dash-sub">@DateTime.Now.ToString("dddd, MMMM dd, yyyy") &nbsp;·&nbsp; Here's your gym at a glance.</p>
        </div>
    </div>

    <!-- ═══ KPI Cards ═══ -->
    <div class="stats-row home-kpi-row">
        @if (isLoading)
        {
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
        }
        else
        {
            <!-- Today's Check-ins -->
            <div class="kpi-card">
                <div class="kpi-icon kpi-icon-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Today's Check-ins</div>
                    <div class="kpi-value kpi-green">@todayCheckInCount</div>
                    <div class="kpi-sub">Members visited today</div>
                </div>
            </div>

            <!-- Expiring This Week -->
            <div class="kpi-card">
                <div class="kpi-icon @(expiringMembers.Any() ? "kpi-icon-red" : "kpi-icon-muted")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Expiring This Week</div>
                    <div class="kpi-value @(expiringMembers.Any() ? "kpi-red" : "")">@expiringMembers.Count</div>
                    <div class="kpi-sub">Memberships expire in 7 days</div>
                </div>
            </div>

            <!-- Total Active -->
            <div class="kpi-card">
                <div class="kpi-icon kpi-icon-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Total Active</div>
                    <div class="kpi-value kpi-blue">@(boxingTaekwondoCount + gymMemberCount + zumbaMemberCount)</div>
                    <div class="kpi-sub">Active members across plans</div>
                </div>
            </div>

            <!-- Total Registered -->
            <div class="kpi-card">
                <div class="kpi-icon kpi-icon-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Total Members</div>
                    <div class="kpi-value kpi-purple">@totalMembers</div>
                    <div class="kpi-sub">All registered members</div>
                </div>
            </div>
        }
    </div>

    @if (!isLoading)
    {
        <!-- ═══ Quick Actions ═══ -->
        <div class="home-quick-actions">
            <button class="quick-action-btn quick-action-primary"
                    @onclick="OpenAddModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Add Member
            </button>
            <button class="quick-action-btn"
                    @onclick='() => NavigationManager.NavigateTo("/admin-attendance")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                Check In Member
            </button>
            <button class="quick-action-btn"
                    @onclick='() => NavigationManager.NavigateTo("/admin-revenue")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                View Revenue
            </button>
            <button class="quick-action-btn"
                    @onclick='() => NavigationManager.NavigateTo("/member-dashboard")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Manage Members
            </button>
        </div>

        <!-- ═══ Membership Category Cards ═══ -->
        <div class="stats-row home-category-row">

            <!-- Boxing / TaekWondo -->
            <div class="ant-card home-member-card @(selectedCategory == 1 ? "home-card-active home-card-active-boxing" : "")"
                 @onclick="() => OnSelectCategory(1)">
                <div class="ant-card-body">
                    <div class="home-card-icon home-icon-boxing">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.82m5.84-2.56a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.82m2.56-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                        </svg>
                    </div>
                    <div class="home-card-content">
                        <div class="home-card-label">Boxing / TaekWondo</div>
                        <div class="home-card-count home-count-boxing">@boxingTaekwondoCount</div>
                        <div class="home-card-sub">Active Members</div>
                    </div>
                    <div class="home-card-hint">@(selectedCategory == 1 ? "Click to hide" : "Click to view members")</div>
                </div>
            </div>

            <!-- Gym Members -->
            <div class="ant-card home-member-card @(selectedCategory == 2 ? "home-card-active home-card-active-gym" : "")"
                 @onclick="() => OnSelectCategory(2)">
                <div class="ant-card-body">
                    <div class="home-card-icon home-icon-gym">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3"/>
                        </svg>
                    </div>
                    <div class="home-card-content">
                        <div class="home-card-label">Gym Members</div>
                        <div class="home-card-count home-count-gym">@gymMemberCount</div>
                        <div class="home-card-sub">Active Members</div>
                    </div>
                    <div class="home-card-hint">@(selectedCategory == 2 ? "Click to hide" : "Click to view members")</div>
                </div>
            </div>

            <!-- Zumba -->
            <div class="ant-card home-member-card @(selectedCategory == 3 ? "home-card-active home-card-active-zumba" : "")"
                 @onclick="() => OnSelectCategory(3)">
                <div class="ant-card-body">
                    <div class="home-card-icon home-icon-zumba">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z"/>
                        </svg>
                    </div>
                    <div class="home-card-content">
                        <div class="home-card-label">Zumba</div>
                        <div class="home-card-count home-count-zumba">@zumbaMemberCount</div>
                        <div class="home-card-sub">Active Members</div>
                    </div>
                    <div class="home-card-hint">@(selectedCategory == 3 ? "Click to hide" : "Click to view members")</div>
                </div>
            </div>

        </div>

        <!-- ═══ Expiring Soon Alert ═══ -->
        @if (expiringMembers.Any())
        {
            <div class="ant-card gym-table-card home-expiring-card">
                <div class="ant-card-body home-expiring-header">
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--danger);flex-shrink:0;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        <span class="dash-title home-expiring-title">Memberships Expiring Within 7 Days</span>
                    </div>
                    <span class="ant-tag ant-tag-red">@expiringMembers.Count expiring</span>
                </div>
                <div class="ant-card-body home-table-body">
                    <table class="gym-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Plan</th>
                                <th>Expiry Date</th>
                                <th>Days Left</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in expiringMembers)
                            {
                                var daysLeft = (m.ExpiryDate!.Value.Date - DateTime.Today).Days;
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:0.6rem;">
                                            <div class="member-avatar-sm">@m.FirstName[0]@m.LastName[0]</div>
                                            <div>
                                                <div class="cell-name">@m.FirstName @m.LastName</div>
                                                <div class="cell-muted" style="font-size:0.75rem;">@m.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="cell-muted">@(m.MemberShipType ?? "—")</td>
                                    <td class="cell-muted">@FormatExpiryDate(m.ExpiryDate)</td>
                                    <td>
                                        <span class="ant-tag @(daysLeft == 0 ? "ant-tag-red" : daysLeft <= 3 ? "ant-tag-orange" : "ant-tag-gold")">
                                            @(daysLeft == 0 ? "Today" : $"{daysLeft}d left")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- ═══ Category Member Table ═══ -->
        @if (selectedCategory > 0)
        {
            var tableTitle = selectedCategory == 1 ? "Boxing / TaekWondo"
                           : selectedCategory == 2 ? "Gym Members"
                           : "Zumba";

            var activeList = selectedCategory == 1 ? boxingMembers
                           : selectedCategory == 2 ? gymMembers
                           : zumbaMembers;

            <div class="ant-card gym-table-card">
                <div class="ant-card-body home-table-header">
                    <span class="dash-title home-table-title">@tableTitle — Members</span>
                    <span class="cell-muted" style="font-size:0.8rem;">@activeList.Count total</span>
                </div>
                <div class="ant-card-body home-table-body">
                    <table class="gym-table">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Phone</th>
                                <th>Date Joined</th>
                                <th>Expiry Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!activeList.Any())
                            {
                                <tr><td colspan="5" class="home-empty-row">No members found.</td></tr>
                            }
                            else
                            {
                                @foreach (var m in activeList)
                                {
                                    <tr>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:0.65rem;">
                                                <div class="member-avatar-sm">@m.FirstName[0]@m.LastName[0]</div>
                                                <div>
                                                    <div class="cell-name">@m.FirstName @m.LastName</div>
                                                    <div class="cell-muted" style="font-size:0.75rem;">@m.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="cell-muted">@(m.Phone ?? "—")</td>
                                        <td class="cell-muted">@m.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        <td class="cell-muted">@FormatExpiryDate(m.ExpiryDate)</td>
                                        <td>
                                            @if (m.IsActive)
                                            {
                                                <span class="ant-tag ant-tag-green">Active</span>
                                            }
                                            else
                                            {
                                                <span class="ant-tag ant-tag-red">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

</div>

<!-- ═══ Add Member Modal ═══ -->
<AddMemberModal IsOpen="showAddModal"
                OnClose="EventCallback.Factory.Create(this, CloseAddModal)"
                OnMemberAdded="EventCallback.Factory.Create(this, async () => await LoadData())" />
