@page "/admin-attendance"
@using AntDesign
@using BaseApplicationMethods
@using MicroGym.Shared.Model

@attribute [Authorize]
@layout MainLayout
@inherits BaseApplication

<PageTitle>Attendance - MicroGym</PageTitle>

<div class="dashboard">

    <!-- ═══ Header ═══ -->
    <div class="dash-header">
        <div>
            <h1 class="dash-title">Attendance</h1>
            <p class="dash-sub">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
        </div>

    </div>



    <!-- ═══ Charts Row ═══ -->
    @if (!isLoading)
    {
        <div class="attn-charts-row">

            <!-- Weekly Trend -->
            <div class="ant-card attn-chart-card">
                <div class="attn-chart-header">
                    <div>
                        <div class="attn-chart-title">Weekly Trend</div>
                        <div class="attn-chart-sub">Check-ins over the last 7 days</div>
                    </div>
                </div>
                <div class="attn-chart-body">
                    @if (!weeklyData.Any())
                    {
                        <div class="attn-chart-empty">No data yet</div>
                    }
                    else
                    {
                        <div class="weekly-chart">
                            @foreach (var day in weeklyData)
                            {
                                var isToday = day.Date.Date == DateTime.Today;
                                var barPct  = WeeklyMax > 0 ? (day.Count * 100 / WeeklyMax) : 0;
                                var minPct  = day.Count > 0 && barPct < 5 ? 5 : barPct;
                                <div class="weekly-col @(isToday ? "weekly-col-today" : "")">
                                    <div class="weekly-count">@(day.Count > 0 ? day.Count.ToString() : "")</div>
                                    <div class="weekly-bar-wrap">
                                        <div class="weekly-bar @(isToday ? "weekly-bar-today" : "")"
                                             style="height: @minPct%;"></div>
                                    </div>
                                    <div class="weekly-day">@day.Date.ToString("ddd")</div>
                                    <div class="weekly-date">@day.Date.ToString("M/d")</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Peak Hours -->
            <div class="ant-card attn-chart-card">
                <div class="attn-chart-header">
                    <div>
                        <div class="attn-chart-title">Peak Hours</div>
                        <div class="attn-chart-sub">
                            @(IsViewingToday ? "Today" : viewDate.ToString("MMM d")) — check-ins by hour
                        </div>
                    </div>
                </div>
                <div class="attn-chart-body">
                    @if (isViewLoading)
                    {
                        <div class="attn-chart-empty"><div class="loader"></div></div>
                    }
                    else if (!viewAttendance.Any())
                    {
                        <div class="attn-chart-empty">No check-ins for this day</div>
                    }
                    else
                    {
                        <div class="peak-chart">
                            @for (int h = 5; h <= 22; h++)
                            {
                                var count  = PeakHoursData.GetValueOrDefault(h, 0);
                                var barPct = PeakHoursMax > 0 ? (count * 100 / PeakHoursMax) : 0;
                                var isPeak = count == PeakHoursMax && count > 0;
                                <div class="peak-row @(count == 0 ? "peak-row-empty" : "") @(isPeak ? "peak-row-top" : "")">
                                    <div class="peak-label">@FormatHour(h)</div>
                                    <div class="peak-track">
                                        <div class="peak-bar @(isPeak ? "peak-bar-top" : "")"
                                             style="width: @(barPct < 2 && count > 0 ? 2 : barPct)%;"></div>
                                    </div>
                                    <div class="peak-right">
                                        <span class="peak-count">@(count > 0 ? count.ToString() : "—")</span>
                                        @if (isPeak)
                                        {
                                            <span class="peak-badge">PEAK</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

        </div>
    }

    <!-- ═══ KPI Stats ═══ -->
    <div class="attn-single-stat">

        <div class="kpi-card attn-kpi-featured">
            <div class="kpi-icon kpi-icon-green">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Today's Check-ins</div>
                <div class="kpi-value kpi-green">@todayAttendance.Count</div>
                <div class="kpi-sub">Members checked in today</div>
            </div>
        </div>

        <button class="kpi-card attn-kpi-add" @onclick="OpenAddModal">
            <div class="kpi-icon kpi-icon-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Quick Action</div>
                <div class="kpi-value" style="font-size:1.5rem;color:var(--accent);">Add Check-In</div>
                <div class="kpi-sub">Log a member's visit</div>
            </div>
        </button>

    </div>

    <!-- ═══ Check-in Search ═══ -->
    <div class="ant-card gym-table-card attn-checkin-card">
        <div class="ant-card-body attn-checkin-body">

            <div class="attn-search-label">Check In a Member</div>

            <div class="toolbar attn-toolbar">
                <span class="ant-input-affix-wrapper ant-input-affix-wrapper-lg gym-input search-input">
                    <span class="ant-input-prefix">🔍</span>
                    <input class="ant-input"
                           type="text"
                           placeholder="Search member by name..."
                           value="@searchText"
                           @oninput="OnSearchInput" />
                </span>
                @if (!string.IsNullOrWhiteSpace(searchText))
                {
                    <button class="ant-btn attn-clear-btn" @onclick="ClearSearch">✕ Clear</button>
                }
            </div>

            <!-- Search Results -->
            @if (searchResults.Any())
            {
                <div class="attn-search-results">
                    @foreach (var member in searchResults)
                    {
                        var alreadyIn = todayAttendance.Any(a => a.UserID == member.UserId);
                        <div class="attn-result-row">
                            <div class="attn-result-info">
                                <span class="cell-name">@member.FirstName @member.LastName</span>
                                <span class="cell-muted attn-result-email">@member.Email</span>
                            </div>
                            <div class="attn-result-action">
                                @if (alreadyIn)
                                {
                                    <span class="ant-tag ant-tag-green">Already Checked In</span>
                                }
                                else if (!IsMembershipValid(member.UserId))
                                {
                                    <button class="ant-btn gym-btn-expired"
                                            @onclick="() => OnExpiredClick(member)">
                                        ⚠ Expired
                                    </button>
                                }
                                else
                                {
                                    <button class="ant-btn ant-btn-primary gym-btn-checkin"
                                            disabled="@isCheckingIn"
                                            @onclick="() => OnCheckIn(member.UserId)">
                                        @if (isCheckingIn && checkingInUserId == member.UserId)
                                        {
                                            <span class="btn-spinner"></span>
                                            <span>Checking in...</span>
                                        }
                                        else
                                        {
                                            <span>✓ Check In</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(searchText))
            {
                <div class="attn-no-results">No members found.</div>
            }

            <!-- Error message — success is handled by the popup below -->
            @if (!string.IsNullOrEmpty(checkInMessage) && !checkInSuccess)
            {
                <div class="ant-alert ant-alert-error ant-alert-with-icon gym-alert attn-alert">
                    <span class="ant-alert-icon">⚠</span>
                    <span class="ant-alert-message">@checkInMessage</span>
                </div>
            }

        </div>
    </div>

    <!-- ═══ Attendance Log ═══ -->
    <div class="ant-card gym-table-card">
        <div class="ant-card-body attn-log-header-body">
            <span class="dash-title attn-log-title">
                Attendance Log
                @if (!IsViewingToday)
                {
                    <span class="attn-log-date-badge">@viewDate.ToString("MMMM d, yyyy")</span>
                }
            </span>
            <div class="attn-log-date-pick">
                <label class="attn-date-label">View date</label>
                <input class="attn-date-input"
                       type="date"
                       value="@ViewDateString"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       @onchange="OnDateChanged" />
                @if (!IsViewingToday)
                {
                    <button class="attn-today-btn" @onclick="OnResetToToday">Today</button>
                }
            </div>
        </div>
        <div class="ant-card-body attn-log-table-body">
            @if (isLoading || isViewLoading)
            {
                <div class="table-state"><div class="loader"></div></div>
            }
            else if (!viewAttendance.Any())
            {
                <div class="table-state">
                    <span class="attn-empty-icon">📋</span>
                    <span>@(IsViewingToday ? "No check-ins yet today." : $"No check-ins on {viewDate:MMM d, yyyy}.")</span>
                </div>
            }
            else
            {
                <table class="gym-table attn-table">
                    <thead>
                        <tr>
                            <th class="attn-col-name">Name</th>
                            <th class="attn-col-type">Membership Type</th>
                            <th class="attn-col-type">Expiry</th>
                            <th class="attn-col-time">Check-in Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in pagedLog)
                        {
                            <tr>
                                <td class="cell-name attn-col-name">@record.FirstName @record.LastName</td>
                                <td class="cell-muted attn-col-type">@record.Name</td>
                                <td class="attn-col-type">
                                    @{
                                        var daysLeft = record.ExpiryDate.HasValue
                                            ? (record.ExpiryDate.Value.Date - DateTime.Today).Days
                                            : (int?)null;
                                    }
                                    @if (daysLeft.HasValue)
                                    {
                                        <span class="ant-tag @GetExpiryTagClass(daysLeft.Value)">@GetExpiryTagText(daysLeft.Value)</span>
                                    }
                                    else
                                    {
                                        <span class="ant-tag ant-tag-muted">N/A</span>
                                    }
                                </td>
                                <td class="cell-muted attn-col-time">@record.CheckInTime.ToString("hh:mm tt")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <PaginationControls CurrentPage="logPage"
                                    TotalPages="logTotalPages"
                                    TotalItems="viewAttendance.Count"
                                    PageSize="LogPageSize"
                                    OnPageChanged="OnLogPageChange" />
            }
        </div>
    </div>

</div>

<!-- ═══ Check-in Success Alert ═══ -->
<GymModal IsOpen="showSuccessAlert"
          Title="Check-in Successful"
          MaxWidth="400px"
          OnClose="CloseSuccessAlert">

    <div style="text-align:center;padding:0.5rem 0 1.25rem;">
        <div style="font-size:3rem;margin-bottom:1rem;">✅</div>
        <p style="margin:0 0 0.35rem;font-size:1.1rem;font-weight:700;color:#F9FAFB;">
            @checkedInMemberName
        </p>
        <p style="margin:0;font-size:0.875rem;color:#22C55E;font-weight:600;">
            Successfully checked in!
        </p>
        <p style="margin:0.5rem 0 0;font-size:0.78rem;color:#6B7280;">
            @DateTime.Now.ToString("hh:mm tt") · @DateTime.Now.ToString("MMMM dd, yyyy")
        </p>
    </div>

    <div class="gym-modal-footer">
        <button class="ant-btn ant-btn-primary gym-btn-primary" @onclick="CloseSuccessAlert">Done</button>
    </div>

</GymModal>

<!-- ═══ Expired Membership Alert ═══ -->
<GymModal IsOpen="showExpiredAlert"
          Title="Membership Expired"
          MaxWidth="420px"
          OnClose="CloseExpiredAlert">

    <div style="text-align:center;padding:0.5rem 0 1.25rem;">
        <div style="font-size:2.5rem;margin-bottom:1rem;">⛔</div>
        <p style="margin:0 0 0.5rem;font-size:1rem;font-weight:700;color:#F9FAFB;">
            @expiredMemberName
        </p>
        <p style="margin:0;font-size:0.875rem;color:#9CA3AF;">
            Membership expired on
            <strong style="color:#EF4444;">
                @(expiredDate.HasValue ? expiredDate.Value.ToString("MMMM dd, yyyy") : "—")
            </strong>
        </p>
        <p style="margin:0.75rem 0 0;font-size:0.8rem;color:#6B7280;">
            Please renew their membership before checking in.
        </p>
    </div>

    <div class="gym-modal-footer">
        <button class="ant-btn" @onclick="CloseExpiredAlert">Close</button>
    </div>

</GymModal>

<!-- ═══ Member Picker Modal ═══ -->
<GymModal IsOpen="showMemberPickerModal"
          Title="Select Member to Check In"
          MaxWidth="720px"
          OnClose="ClosePickerModal">

    <div style="position:relative;margin-bottom:6px;">
        <input class="gym-modal-search-input"
               type="text"
               placeholder="🔍  Search by name..."
               value="@modalSearchText"
               @oninput="OnModalSearchInput" />
    </div>

    <div class="modal-member-count">
        @ModalFilteredMembers.Count member@(ModalFilteredMembers.Count != 1 ? "s" : "")
    </div>

    <div class="modal-member-list">
        @if (!ModalFilteredMembers.Any())
        {
            <div class="modal-member-empty">No members found.</div>
        }
        else
        {
            @foreach (var member in ModalFilteredMembers)
            {
                var alreadyIn = todayAttendance.Any(a => a.UserID == member.UserId);
                var isExpired = !IsMembershipValid(member.UserId);

                <div class="modal-member-row @(alreadyIn || isExpired ? "dimmed" : "")">
                    <div class="modal-member-left">
                        <div class="modal-member-avatar @(isExpired ? "modal-member-avatar--expired" : "")">
                            @member.FirstName[0]@member.LastName[0]
                        </div>
                        <div class="modal-member-info">
                            <span class="modal-member-name">@member.FirstName @member.LastName</span>
                            <span class="modal-member-expiry @(isExpired ? "modal-member-expiry--expired" : "")">
                                @FormatExpiryDate(member.ExpiryDate)
                            </span>
                        </div>
                    </div>
                    <div class="modal-member-right">
                        @if (alreadyIn)
                        {
                            <span class="modal-checkedin-badge">✓ Checked In</span>
                        }
                        else if (isExpired)
                        {
                            <button class="ant-btn gym-btn-expired"
                                    @onclick="() => OnModalExpiredClick(member)">
                                ⚠ Expired
                            </button>
                        }
                        else
                        {
                            <Button Class="gym-btn-checkin"
                                    Disabled="@isCheckingIn"
                                    Loading="@(isCheckingIn && checkingInUserId == member.UserId)"
                                    OnClick="() => OnModalCheckIn(member.UserId)">
                                ✓ Check In
                            </Button>
                        }
                    </div>
                </div>
            }
        }
    </div>

</GymModal>
