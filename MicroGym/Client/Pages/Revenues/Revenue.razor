@page "/admin-revenue"
@using BaseApplicationMethods
@using MicroGym.Shared.Model
@attribute [Authorize]
@layout MainLayout
@inherits BaseApplication

<PageTitle>Revenue - MicroGym</PageTitle>

@* ═══ Revenue PIN Lock ═══ *@
@if (isRevenueLocked)
{
    <div class="rev-lock-overlay">
        <div class="rev-lock-modal">

            <div class="rev-lock-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                </svg>
            </div>

            <h2 class="rev-lock-title">Revenue Access</h2>
            <p class="rev-lock-sub">This section is restricted.<br/>Enter your PIN to continue.</p>

            @if (!string.IsNullOrEmpty(pinError))
            {
                <div class="rev-lock-error">@pinError</div>
            }

            <input class="rev-lock-input"
                   type="password"
                   placeholder="Enter PIN"
                   value="@pinInput"
                   @oninput="@(e => pinInput = e.Value?.ToString() ?? string.Empty)"
                   @onkeydown="OnPinKeyDown"
                   autocomplete="off"/>

            <button class="rev-lock-btn" @onclick="OnUnlockRevenue">
                Unlock Revenue
            </button>

        </div>
    </div>
}
else
{

<div class="dashboard">

    <!-- ═══ Header ═══ -->
    <div class="dash-header">
        <div>
            <h1 class="dash-title">Revenue</h1>
            <p class="dash-sub">Track gym earnings, income, and expenses</p>
        </div>

        <!-- Month / Year Filter -->
        <div class="rev-filter">
            <select class="gym-select" value="@selectedMonth" @onchange="OnMonthChange">
                <option value="1">January</option>
                <option value="2">February</option>
                <option value="3">March</option>
                <option value="4">April</option>
                <option value="5">May</option>
                <option value="6">June</option>
                <option value="7">July</option>
                <option value="8">August</option>
                <option value="9">September</option>
                <option value="10">October</option>
                <option value="11">November</option>
                <option value="12">December</option>
            </select>
            <select class="gym-select" value="@selectedYear" @onchange="OnYearChange">
                @foreach (var y in availableYears)
                {
                    <option value="@y">@y</option>
                }
            </select>
        </div>
    </div>

    <!-- ═══ KPI Stat Cards ═══ -->
    @if (isLoading)
    {
        <div class="stats-row stats-row--4">
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
            <div class="kpi-card kpi-loading"><div class="loader"></div></div>
        </div>
    }
    else
    {
        <div class="stats-row stats-row--4">

            <!-- Total Earnings -->
            <div class="kpi-card">
                <div class="kpi-icon kpi-icon-gold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Total Earnings</div>
                    <div class="kpi-value kpi-gold">₱@totalEarnings.ToString("N2")</div>
                    <div class="kpi-sub">@selectedYear total income</div>
                </div>
            </div>

            <!-- Monthly Income -->
            <div class="kpi-card">
                <div class="kpi-icon kpi-icon-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Monthly Income</div>
                    <div class="kpi-value kpi-green">₱@monthlyIncome.ToString("N2")</div>
                    <div class="kpi-sub">@selectedMonthLabel @selectedYear</div>
                    <div class="kpi-mom @MoMClass">@MoMText</div>
                </div>
            </div>

            <!-- Monthly Expense -->
            <div class="kpi-card">
                <div class="kpi-icon kpi-icon-red">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 13l-5 5m0 0l-5-5m5 5V6"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Monthly Expense</div>
                    <div class="kpi-value kpi-red">₱@monthlyExpense.ToString("N2")</div>
                    <div class="kpi-sub">@selectedMonthLabel @selectedYear</div>
                </div>
            </div>

            <!-- Net Income -->
            <div class="kpi-card">
                <div class="kpi-icon @(monthlyNet >= 0 ? "kpi-icon-blue" : "kpi-icon-red")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-label">Net Income</div>
                    <div class="kpi-value @(monthlyNet >= 0 ? "kpi-blue" : "kpi-red")">₱@monthlyNet.ToString("N2")</div>
                    <div class="kpi-sub">Income minus expenses</div>
                </div>
            </div>

        </div>

        <!-- ═══ Breakdown Row ═══ -->
        <div class="rev-breakdown-row">

            <!-- Plan vs Tier -->
            <div class="rev-breakdown-card">
                <div class="rev-breakdown-title">Income by Type</div>
                <div class="rev-breakdown-items">
                    <div class="rev-breakdown-item">
                        <span class="rev-breakdown-dot rev-breakdown-dot--plan"></span>
                        <span class="rev-breakdown-label">Subscription</span>
                        <span class="rev-breakdown-value">₱@planIncome.ToString("N2")</span>
                    </div>
                    <div class="rev-breakdown-item">
                        <span class="rev-breakdown-dot rev-breakdown-dot--tier"></span>
                        <span class="rev-breakdown-label">Annual Membership</span>
                        <span class="rev-breakdown-value">₱@tierIncome.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <!-- Payment Methods -->
            <div class="rev-breakdown-card">
                <div class="rev-breakdown-title">Income by Payment Method</div>
                <div class="rev-breakdown-items">
                    @if (!paymentMethodBreakdown.Any())
                    {
                        <span class="rev-breakdown-empty">No income this month</span>
                    }
                    else
                    {
                        @foreach (var (method, amount) in paymentMethodBreakdown)
                        {
                            <div class="rev-breakdown-item">
                                <span class="rev-breakdown-dot rev-breakdown-dot--method"></span>
                                <span class="rev-breakdown-label">@method</span>
                                <span class="rev-breakdown-value">₱@amount.ToString("N2")</span>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>
    }

    <!-- ═══ Revenue Chart ═══ -->
    <div class="ant-card rev-chart-card" style="margin-bottom:1.5rem;">
        <div class="ant-card-body rev-chart-header">
            <div>
                <p class="rev-chart-title">Monthly Revenue Overview — @selectedYear</p>
                <p class="rev-chart-sub">Income vs Expense across all 12 months</p>
            </div>
        </div>
        <div class="ant-card-body rev-chart-body">
            @if (chartLoading)
            {
                <div class="rev-chart-loading">
                    <div class="loader"></div>
                    <span>Loading chart data...</span>
                </div>
            }
            else
            {
                <div class="rev-chart-wrap">
                    <canvas id="revenue-chart"></canvas>
                </div>
            }
        </div>
    </div>

    <!-- ═══ Transaction Table ═══ -->
    @if (!isLoading)
    {
        <div class="ant-card rev-table-card">
            <div class="ant-card-body rev-chart-header">
                <div>
                    <p class="rev-chart-title">Transactions — @selectedMonthLabel @selectedYear</p>
                    <p class="rev-chart-sub">
                        @paymentDetails.Count(p => p.Status == "Paid") paid
                        @if (paymentDetails.Any(p => p.Status == "Expense"))
                        {
                            <span> · @paymentDetails.Count(p => p.Status == "Expense") expense</span>
                        }
                        @if (txTotalPages > 1)
                        {
                            <span> · page @txPage of @txTotalPages</span>
                        }
                    </p>
                </div>
            </div>
            <div class="ant-card-body" style="padding-top:0; padding-bottom:0;">
                @if (!paymentDetails.Any())
                {
                    <div class="rev-table-empty">No transactions for @selectedMonthLabel @selectedYear.</div>
                }
                else
                {
                    <table class="rev-table">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Plan</th>
                                <th>Method</th>
                                <th>Date</th>
                                <th>Type</th>
                                <th class="rev-table-amount">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in pagedTransactions)
                            {
                                <tr>
                                    <td class="rev-table-name">@p.FirstName @p.LastName</td>
                                    <td class="cell-muted">@(string.IsNullOrEmpty(p.PlanName) ? "—" : p.PlanName)</td>
                                    <td class="cell-muted">@p.PaymentMethod</td>
                                    <td class="cell-muted">@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <span class="rev-type-tag @(p.PaymentType == "Tier" ? "rev-type-tier" : "rev-type-plan")">
                                            @(p.PaymentType == "Tier" ? "Annual" : "Plan")
                                        </span>
                                    </td>
                                    <td class="rev-table-amount @(p.Status == "Expense" ? "kpi-red" : "kpi-green")">
                                        @(p.Status == "Expense" ? "−" : "+")₱@p.AmountPaid.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (txTotalPages > 1)
                    {
                        <div class="rev-pagination">
                            <button class="rev-page-btn" disabled="@(txPage == 1)"
                                    @onclick="() => OnTxPageChange(txPage - 1)">←</button>

                            @for (int i = 1; i <= txTotalPages; i++)
                            {
                                var p = i;
                                <button class="rev-page-btn @(txPage == p ? "rev-page-btn--active" : "")"
                                        @onclick="() => OnTxPageChange(p)">@p</button>
                            }

                            <button class="rev-page-btn" disabled="@(txPage == txTotalPages)"
                                    @onclick="() => OnTxPageChange(txPage + 1)">→</button>
                        </div>
                    }
                }
            </div>
        </div>
    }

</div>

} @* end else (unlocked) *@
