<nav class="top-navbar">

    <!-- Brand -->
    <a href="/" class="navbar-brand-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
        MICRO<span class="brand-accent">GYM</span>
    </a>

    <!-- Left Nav Links -->
    <div class="navbar-left-links">
        <AuthorizeView>
            <Authorized>
                <NavLink class="nav-link-item" href="" Match="NavLinkMatch.All">
                    Home
                </NavLink>
                <NavLink class="nav-link-item" href="member-dashboard">
                    Members
                </NavLink>
            </Authorized>
        </AuthorizeView>
    </div>

    <!-- Right: Logout -->
    <div class="navbar-right">
        <AuthorizeView>
            <Authorized>
                <button class="nav-logout-btn" @onclick="HandleLogout">
                    Logout
                </button>
            </Authorized>
            <NotAuthorized>
                <NavLink class="nav-link-item" href="login">Sign In</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <!-- Mobile toggle -->
    <button class="mobile-toggle" @onclick="ToggleNavMenu">☰</button>

</nav>

<!-- Mobile dropdown -->
<div class="mobile-menu @(collapseNavMenu ? "hidden" : "")">
    <AuthorizeView>
        <Authorized>
            <NavLink class="mobile-nav-item" href="" Match="NavLinkMatch.All" @onclick="ToggleNavMenu">Home</NavLink>
            <NavLink class="mobile-nav-item" href="member-dashboard" @onclick="ToggleNavMenu">Members</NavLink>
            <button class="mobile-nav-item mobile-logout" @onclick="HandleLogout">Logout</button>
        </Authorized>
        <NotAuthorized>
            <NavLink class="mobile-nav-item" href="login" @onclick="ToggleNavMenu">Sign In</NavLink>
        </NotAuthorized>
    </AuthorizeView>
</div>
